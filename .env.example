# Copy to .env and fill in your keys.

# ===== REQUIRED =====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
PUBMED_EMAIL=your.email@example.com   # NCBI policy requires identifying email

# ===== RECOMMENDED =====
NCBI_API_KEY=                # https://www.ncbi.nlm.nih.gov/account/ (free, 3->10 req/s)

# ===== OPTIONAL =====
TAVILY_API_KEY=              # https://tavily.com (web search for FDA/news)
PAPERCLIP_API_KEY=           # https://paperclip.gxl.ai (8M+ paper corpus: PMC + bioRxiv + medRxiv + arXiv)
FIRECRAWL_API_KEY=           # https://firecrawl.dev (full-text deepening for top citations)

# Embedding provider (optional — enables Tier C semantic cache). Pick ONE.
VOYAGE_API_KEY=              # https://voyageai.com  (recommended; Anthropic-aligned)
# OPENAI_API_KEY=
# COHERE_API_KEY=

SUPABASE_URL=                # https://<project>.supabase.co
SUPABASE_SERVICE_KEY=        # service_role key for cache writes
SUPABASE_ANON_KEY=           # not required server-side
USE_SUPABASE_CACHE=false
USE_SEMANTIC_CACHE=false     # requires an embedding key + pgvector migration

# ===== TUNING =====
MAX_PUBMED=5
MAX_TRIALS=5
MAX_PREPRINTS=3
USE_WEB_SEARCH=false
