# Copy to .env and fill in your keys.

# ===== REQUIRED =====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
PUBMED_EMAIL=your.email@example.com   # NCBI policy requires identifying email

# ===== RECOMMENDED =====
NCBI_API_KEY=                # https://www.ncbi.nlm.nih.gov/account/ (free, 3->10 req/s)

# ===== OPTIONAL =====
TAVILY_API_KEY=              # https://tavily.com (web search for FDA/news)
SUPABASE_URL=                # https://<project>.supabase.co
SUPABASE_SERVICE_KEY=        # service_role key for cache writes
SUPABASE_ANON_KEY=           # not required server-side
USE_SUPABASE_CACHE=false

# ===== TUNING =====
MAX_PUBMED=5
MAX_TRIALS=5
MAX_PREPRINTS=3
USE_WEB_SEARCH=false
